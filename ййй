name: Build APK
on: [push]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup Flutter
        uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.41.2'
          channel: 'stable'
      
      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'
      
      - name: Install flet
        run: pip install flet
      
      - name: Create test app
        run: |
          mkdir -p myapp
          cd myapp
          echo "import flet as ft" > main.py
          echo "" >> main.py
          echo "def main(page: ft.Page):" >> main.py
          echo "    page.add(ft.Text('Hello World'))" >> main.py
          echo "" >> main.py
          echo "ft.app(target=main)" >> main.py
      
      - name: Build APK
        run: |
          cd myapp
          flet create .  # конвертирует в flutter проект
          flutter pub get
          flutter build apk --release
      
      - name: Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: app-release
          path: myapp/build/app/outputs/flutter-apk/app-release.apk
